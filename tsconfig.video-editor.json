{
	"compilerOptions": {
		"target": "ES2022",
		"useDefineForClassFields": true,
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"baseUrl": ".",
		"paths": {
			"@video-editor/*": ["src/video-editor/*"]
		},
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"allowImportingTsExtensions": false,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"noEmit": true,
		"jsx": "react-jsx",
		"strict": true,
		"skipLibCheck": true,
		"types": ["vite/client", "vitest/globals", "react", "react-dom"]
	},
	"include": ["src/video-editor/**/*", "vite.video-editor.config.js", "vitest.video-editor.config.js"]
}
