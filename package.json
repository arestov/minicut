{
  "name": "minicut",
  "version": "1.0.0",
  "description": "Video editor harness built from the Linkkraft plan slice",
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "dev": "npm run dev:full",
    "dev:full": "node ./scripts/dev-full.mjs",
    "start": "node ./scripts/start.mjs",
    "test": "npm run test:video-editor",
    "test:video-editor": "npm run test:video-editor:shared && npm run test:video-editor:isolated",
    "test:video-editor:shared": "vitest run --config vitest.video-editor.config.js",
    "test:video-editor:isolated": "vitest run --config vitest.video-editor.isolated.config.js",
    "test:video-editor:node": "vitest run --config vitest.video-editor.node.config.js",
    "test:video-editor:crdt": "vitest run --config vitest.video-editor.crdt.config.js",
    "bench:video-editor": "vitest bench --config vitest.video-editor.config.js src/video-editor/worker/renderIndexProjection.bench.ts",
    "test:integration": "npm run test:integration:fast && npm run test:integration:p2p",
    "test:integration:fast": "playwright test",
    "test:integration:fast:shared-cache": "node scripts/run-with-shared-vite-cache.cjs test:integration:fast",
    "test:integration:p2p": "playwright test -c playwright.p2p.config.js",
    "test:integration:p2p:shared-cache": "node scripts/run-with-shared-vite-cache.cjs test:integration:p2p",
    "test:integration:p2p:smoke": "playwright test -c playwright.p2p.config.js --grep-invert @slow",
    "test:integration:p2p:smoke:shared-cache": "node scripts/run-with-shared-vite-cache.cjs test:integration:p2p:smoke",
    "test:integration:p2p:slow": "playwright test -c playwright.p2p.config.js --grep @slow",
    "test:integration:shared-cache": "node scripts/run-with-shared-vite-cache.cjs test:integration",
    "test:integration:export": "playwright test tests/integration/export-audio-artifacts.spec.ts",
    "test:integration:profile": "playwright test tests/integration/color-scopes-profile.spec.ts",
    "test:integration:serial": "playwright test --workers=1",
    "repl:run": "node --import ./test/repl/register-dkt-alias-loader.mjs --import tsx ./test/repl/run.mjs",
    "repl:playwright": "node ./test/repl/playwright-run.mjs",
    "repl:playwright:runtime": "node ./test/repl/playwright-runtime-inspect.testing.mjs",
    "repl:playwright:css": "node ./test/repl/playwright-css-inspect.mjs",
    "video-editor:dev": "vite --config vite.video-editor.config.js",
    "video-editor:build": "vite build --config vite.video-editor.config.js",
    "structure:snapshot": "node --import ./test/repl/register-dkt-alias-loader.mjs --import tsx ./dev/write-dkt-structure.mjs",
    "structure:view": "npm --prefix ./dev/structure-graph-viewer run dev",
    "structure": "npm run structure:snapshot && npm run structure:view",
    "bench:color-scopes": "node --import tsx ./scripts/bench-color-scopes.ts",
    "guard:dkt-hard": "node ./scripts/check-dkt-hard-guardrails.mjs",
    "node:headless:run": "node --import tsx ./src/video-editor/node/cli.ts --scenario ./tests/fixtures/headless/sample-scenario.json",
    "node:headless:scenario": "node --import tsx ./src/video-editor/node/cli.ts",
    "deploy:frontend": "node ./scripts/deploy-frontend.mjs",
    "deploy": "npm run deploy:frontend"
  },
  "dependencies": {
    "@legendapp/state": "^3.0.0-beta.47",
    "fix-webm-duration": "^1.0.6",
    "lucide-react": "^1.14.0",
    "nanoid": "^5.1.6",
    "react": "^19.2.5",
    "react-dom": "^19.2.0",
    "webm-muxer": "^5.1.4"
  },
  "devDependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@ffprobe-installer/ffprobe": "^2.1.2",
    "@playwright/test": "^1.55.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.0.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^7.1.10",
    "vitest": "^4.1.0"
  }
}
