{
  "name": "minicut",
  "version": "1.0.0",
  "description": "Video editor harness built from the Linkkraft plan slice",
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "dev:full": "node ./scripts/dev-full.mjs",
    "start": "node ./scripts/start.mjs",
    "test": "vitest --run --config vitest.video-editor.config.js",
    "test:video-editor": "vitest --run --config vitest.video-editor.config.js",
    "test:video-editor:node": "vitest --run --config vitest.video-editor.node.config.js",
    "bench:video-editor": "vitest bench --run --config vitest.video-editor.config.js src/video-editor/worker/renderIndexProjection.bench.ts",
    "test:integration": "playwright test",
    "video-editor:dev": "vite --config vite.video-editor.config.js",
    "video-editor:build": "vite build --config vite.video-editor.config.js",
    "node:headless:run": "node --import tsx ./src/video-editor/node/cli.ts --scenario ./tests/fixtures/headless/sample-scenario.json",
    "node:headless:scenario": "node --import tsx ./src/video-editor/node/cli.ts",
    "deploy:frontend": "node ./scripts/deploy-frontend.mjs",
    "deploy": "npm run deploy:frontend"
  },
  "dependencies": {
    "@legendapp/state": "^3.0.0-beta.47",
    "fix-webm-duration": "^1.0.6",
    "lucide-react": "^1.14.0",
    "nanoid": "^5.1.6",
    "react": "^19.2.5",
    "react-dom": "^19.2.0",
    "webm-muxer": "^5.1.4"
  },
  "devDependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@ffprobe-installer/ffprobe": "^2.1.2",
    "@playwright/test": "^1.55.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "jsdom": "^29.0.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^7.1.10",
    "vitest": "^4.1.0"
  }
}
